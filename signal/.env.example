# Local `npm run dev` — browser calls OpenAI directly (CORS allows localhost)
VITE_OPENAI_API_KEY=

# `vite preview` or special cases: set to `false` to keep using VITE_OPENAI_API_KEY instead of /api/score
# VITE_USE_API_PROXY=false

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Must match your Supabase table name. Default is signal_leads (spec). Use leads if your table is named `leads`:
# VITE_SUPABASE_LEADS_TABLE=leads

# Optional — drop-off table (default signal_completions)
# VITE_SUPABASE_COMPLETIONS_TABLE=signal_completions

# Optional — reserved for future Gemini-based experiments (not used by SIGNAL yet)
VITE_GEMINI_API_KEY=

# --- Vercel (Dashboard → Environment Variables), not Vite-prefixed: ---
# OPENAI_API_KEY=              # server-only; used by api/score.mjs (required for production scoring)
# SUPABASE_SERVICE_ROLE_KEY=   # server-only; used by api/save-lead.mjs (required for production lead capture — bypasses RLS)
# SUPABASE_URL=                # optional duplicate of VITE_SUPABASE_URL for server routes if you prefer not to use VITE_ on the server
